{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@repo/core": ["../../packages/core/src"],
      "@repo/core/*": ["../../packages/core/src/*"],
      "@repo/features": ["../../packages/features/src"],
      "@repo/features/*": ["../../packages/features/src/*"],
      "@repo/api": ["../../packages/api/src"],
      "@repo/api/*": ["../../packages/api/src/*"],
      "@repo/api-mocks": ["../../packages/api-mocks/src"],
      "@repo/api-mocks/*": ["../../packages/api-mocks/src/*"],
      "@repo/types": ["../../packages/types/src"],
      "@repo/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src"]
}
